# Terra OBIA environment configuration
TERRA_ENV=development
TERRA_LOG_LEVEL=INFO
TERRA_API_HOST=0.0.0.0
TERRA_API_PORT=8000

# Optional API key (unset in development = no auth required)
# TERRA_API_KEY=change-me-in-production

# Model artifacts and job output directories
TERRA_MODELS_DIR=models
TERRA_JOB_OUTPUT_DIR=outputs/jobs
TERRA_DATA_DIR=data
